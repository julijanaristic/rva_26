<Window
    x:Class="AirportTerminalMonitoring.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AirportTerminalMonitoring.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="400"
    Height="250"
    mc:Ignorable="d">
    <StackPanel>
        <Button
            Width="200"
            Height="50"
            Margin="10"
            Click="Terminals_Click"
            Content="Airport Terminals" />
        <Button
            Width="200"
            Height="50"
            Margin="10"
            Click="Activities_Click"
            Content="Terminal Activities" />
    </StackPanel>
</Window>
