<Window
    x:Class="AirportTerminalMonitoring.WPF.Views.TerminalWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AirportTerminalMonitoring.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TerminalWindow"
    Width="800"
    Height="500"
    mc:Ignorable="d">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <TextBox
                Width="200"
                Margin="5"
                Text="{Binding SearchText}" />
            <Button
                Margin="5"
                Command="{Binding SearchCommand}"
                Content="Search" />
            <Button
                Margin="5"
                Command="{Binding AddCommand}"
                Content="Add" />
            <Button
                Margin="5"
                Command="{Binding EditCommand}"
                Content="Edit" />
            <Button
                Margin="5"
                Command="{Binding DeleteCommand}"
                Content="Delete" />
            <Button
                Margin="5"
                Command="{Binding UndoCommand}"
                Content="Undo" />
            <Button
                Margin="5"
                Command="{Binding RedoCommand}"
                Content="Redo" />
        </StackPanel>

        <DataGrid
            AutoGenerateColumns="False"
            ItemsSource="{Binding Terminals}"
            SelectedItem="{Binding SelectedTerminal}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Code}" Header="Code" />
                <DataGridTextColumn Binding="{Binding AirportName}" Header="Airport" />
                <DataGridTextColumn Binding="{Binding GateCount}" Header="Gates" />
                <DataGridTextColumn Binding="{Binding DirectExit}" Header="Direct Exit" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
