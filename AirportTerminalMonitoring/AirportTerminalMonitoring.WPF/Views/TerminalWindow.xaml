<Window
    x:Class="AirportTerminalMonitoring.WPF.Views.TerminalWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AirportTerminalMonitoring.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TerminalWindow"
    Width="900"
    Height="700"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F7F4EF"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#E5E1DA"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#A89F91"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#8F8678"/>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter
                                    TargetName="border"
                                    Property="Background"
                                    Value="{StaticResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource BackgroundBrush}">
        <DockPanel Margin="20">
            <Border
                DockPanel.Dock="Top"
                Padding="15"
                Margin="0 0 0 15"
                Background="{StaticResource CardBrush}"
                CornerRadius="25"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="220"
                        Height="38"
                        Margin="5"
                        CornerRadius="15"
                        BorderBrush="{StaticResource BorderBrushCustom}"
                        BorderThickness="1"
                        Background="White">
                        <TextBox
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="10,7"
                            Text="{Binding SearchText}" />
                    </Border>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Search"
                        Command="{Binding SearchCommand}"/>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Add"
                        Command="{Binding AddCommand}"/>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Edit"
                        Command="{Binding EditCommand}"/>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Delete"
                        Command="{Binding DeleteCommand}"/>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Undo"
                        Command="{Binding UndoCommand}"/>
                    <Button
                        Style="{StaticResource RoundedButton}"
                        Width="80"
                        Height="35"
                        Margin="5"
                        Content="Redo"
                        Command="{Binding RedoCommand}"/>
                </StackPanel>
            </Border>
            <Border
                Background="{StaticResource CardBrush}"
                CornerRadius="25"
                Padding="15"
                ClipToBounds="True"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="1">
                <DataGrid
                    Background="Transparent"
                    BorderThickness="0"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    RowHeight="35"
                    FontSize="14"
                    ItemsSource="{Binding Terminals}"
                    SelectedItem="{Binding SelectedTerminal}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#ECE7E1"/>
                            <Setter Property="Foreground" Value="#4A4642"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#FAF9F7"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Binding="{Binding Code}"
                            Header="Code"/>
                        <DataGridTextColumn
                            Binding="{Binding AirportName}"
                            Header="Airport"/>
                        <DataGridTextColumn
                            Binding="{Binding GateCount}"
                            Header="Gates"/>
                        <DataGridTextColumn
                            Binding="{Binding DirectExit}"
                            Header="Direct Exit"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>
    </Grid>
</Window>
