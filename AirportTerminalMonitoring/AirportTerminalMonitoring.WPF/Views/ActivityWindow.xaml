<Window
    x:Class="AirportTerminalMonitoring.WPF.Views.ActivityWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AirportTerminalMonitoring.WPF.Views"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ActivityWindow"
    Width="800"
    Height="450">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <TextBox
                Width="200"
                Margin="5"
                Text="{Binding SearchText}" />
            <Button
                Margin="5"
                Command="{Binding SearchCommand}"
                Content="Search" />
            <Button
                Margin="5"
                Command="{Binding AddCommand}"
                Content="Add" />
            <Button
                Margin="5"
                Command="{Binding EditCommand}"
                Content="Edit" />
            <Button
                Margin="5"
                Command="{Binding DeleteCommand}"
                Content="Delete" />
            <Button
                Margin="5"
                Command="{Binding UndoCommand}"
                Content="Undo" />
            <Button
                Margin="5"
                Command="{Binding RedoCommand}"
                Content="Redo" />
        </StackPanel>

        <DataGrid
            AutoGenerateColumns="False"
            ItemsSource="{Binding Activities}"
            SelectedItem="{Binding SelectedActivity}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding PassengerCount}" Header="Passengers" />
                <DataGridTextColumn Binding="{Binding AverageWaitTime}" Header="Wait Time" />
                <DataGridTextColumn Binding="{Binding NumberOfDelays}" Header="Delays" />
                <DataGridTextColumn Binding="{Binding CollectionTime}" Header="Collection Time" />
                <DataGridTextColumn Binding="{Binding State}" Header="State" />
            </DataGrid.Columns>
        </DataGrid>

        <lvc:CartesianChart Series="{Binding Series}" XAxes="{Binding XAxes}" />
    </DockPanel>
</Window>
