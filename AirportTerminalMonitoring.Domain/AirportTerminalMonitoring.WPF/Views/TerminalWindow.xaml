<Window x:Class="AirportTerminalMonitoring.WPF.Views.TerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportTerminalMonitoring.WPF.Views"
        mc:Ignorable="d"
        Title="TerminalWindow" Height="500" Width="800">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <TextBox Width="200" Margin="5" Text="{Binding SearchText}"/>
            <Button Content="Search" Margin="5" Command="{Binding SearchCommand}"/>
            <Button Content="Add" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Edit" Margin="5" Command="{Binding EditCommand}"/>
            <Button Content="Delete" Margin="5" Command="{Binding DeleteCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Terminals}" SelectedItem="{Binding SelectedTerminal}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}"/>
                <DataGridTextColumn Header="Airport" Binding="{Binding AirportName}"/>
                <DataGridTextColumn Header="Gates" Binding="{Binding GateCount}"/>
                <DataGridTextColumn Header="Direct Exit" Binding="{Binding DirectExit}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
